{
  "name": "survey-utils",
  "version": "1.0.0",
  "description": "Utility library for SurveyJS localization and translation management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "survey-utils": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/surveyjs/survey-utils.git"
  },
  "keywords": [
    "surveyjs",
    "localization",
    "translation",
    "i18n",
    "utilities"
  ],
  "author": "SurveyJS Team",
  "license": "MIT",
  "dependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.1.0",
    "ajv": "^8.20.0",
    "dotenv": "^17.4.2",
    "jsdom": "^26.0.0",
    "json5": "^2.0.0",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "check:unused-strings": "node ./dist/cli.js check-strings",
    "translate": "node ./dist/cli.js translate",
    "generate-doc": "node ./dist/cli.js generate-doc",
    "debug": "ts-node src/translateLibrary.ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*",
    "allowlists/**/*",
    "static/**/*",
    "README.md"
  ]
}
