{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug translateCreator.ts",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/translateCreator.ts",
      "runtimeArgs": ["-r", "ts-node/register"],
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ]
    },
    {
      "name": "Debug translateLibrary.ts",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/src/translateLibrary.ts",
      "runtimeArgs": ["-r", "ts-node/register"],
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ]
    },
    {
      "name": "Debug translateLibrary.ts (Compiled)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/dist/translateLibrary.js",
      "preLaunchTask": "tsc: build - tsconfig.json",
      "env": {
        "NODE_ENV": "development"
      },
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "sourceMaps": true,
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ]
    }
  ]
}
